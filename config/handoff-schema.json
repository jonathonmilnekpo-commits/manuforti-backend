{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Agent Handoff Schema",
  "description": "Structured format for inter-agent communication and task handoffs",
  "type": "object",
  "required": ["version", "from", "to", "timestamp", "context", "deliverables", "status"],
  "properties": {
    "version": {
      "type": "string",
      "description": "Schema version",
      "enum": ["1.0"]
    },
    "handoffId": {
      "type": "string",
      "description": "Unique identifier for this handoff (UUID)"
    },
    "from": {
      "type": "string",
      "description": "Name of the agent handing off the task",
      "enum": ["Vetter", "Researcher", "Venture", "Validator", "Aiden", "Crab", "Doctor", "Eirik", "User"]
    },
    "to": {
      "type": "string",
      "description": "Name of the agent receiving the task",
      "enum": ["Vetter", "Researcher", "Venture", "Validator", "Aiden", "Crab", "Doctor", "Eirik", "User"]
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of the handoff"
    },
    "orderId": {
      "type": "string",
      "description": "Associated order/job identifier (e.g., MF-2026-001)"
    },
    "context": {
      "type": "object",
      "description": "Context and state information for the receiving agent",
      "properties": {
        "taskDescription": {
          "type": "string",
          "description": "Description of what needs to be done"
        },
        "priority": {
          "type": "string",
          "enum": ["critical", "high", "normal", "low"],
          "description": "Task priority level"
        },
        "deadline": {
          "type": "string",
          "format": "date-time",
          "description": "Deadline for task completion"
        },
        "dependencies": {
          "type": "array",
          "items": {"type": "string"},
          "description": "List of dependencies that must be resolved first"
        },
        "constraints": {
          "type": "array",
          "items": {"type": "string"},
          "description": "Any constraints or limitations"
        }
      }
    },
    "deliverables": {
      "type": "array",
      "description": "List of outputs produced by the sending agent",
      "items": {
        "type": "object",
        "required": ["name", "type", "location"],
        "properties": {
          "name": {
            "type": "string",
            "description": "Name of the deliverable"
          },
          "type": {
            "type": "string",
            "enum": ["file", "data", "url", "text", "image", "report"],
            "description": "Type of deliverable"
          },
          "location": {
            "type": "string",
            "description": "Path or URL to the deliverable"
          },
          "format": {
            "type": "string",
            "description": "File format (e.g., json, md, docx, pdf)"
          },
          "size": {
            "type": "string",
            "description": "Size of the deliverable (for files)"
          },
          "checksum": {
            "type": "string",
            "description": "MD5 or SHA checksum for verification"
          },
          "description": {
            "type": "string",
            "description": "Brief description of the deliverable content"
          }
        }
      }
    },
    "status": {
      "type": "string",
      "enum": ["complete", "partial", "failed", "blocked", "in_progress"],
      "description": "Status of the work being handed off"
    },
    "metrics": {
      "type": "object",
      "description": "Performance metrics for this stage",
      "properties": {
        "durationMs": {
          "type": "integer",
          "description": "Time taken to complete the work"
        },
        "tokensUsed": {
          "type": "integer",
          "description": "Total tokens consumed"
        },
        "costUsd": {
          "type": "number",
          "description": "Estimated cost in USD"
        },
        "successRate": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Success rate (0.0 - 1.0)"
        }
      }
    },
    "notes": {
      "type": "string",
      "description": "Additional notes or context for the receiving agent"
    },
    "blockers": {
      "type": "array",
      "items": {"type": "string"},
      "description": "Any blockers or issues the receiving agent should know about"
    },
    "nextSteps": {
      "type": "array",
      "items": {"type": "string"},
      "description": "Recommended next steps for the receiving agent"
    },
    "history": {
      "type": "array",
      "description": "Chain of previous handoffs in this pipeline",
      "items": {
        "type": "object",
        "properties": {
          "from": {"type": "string"},
          "to": {"type": "string"},
          "timestamp": {"type": "string", "format": "date-time"},
          "status": {"type": "string"}
        }
      }
    }
  }
}
