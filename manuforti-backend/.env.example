# Server Configuration
PORT=3000
NODE_ENV=development

# Database (PostgreSQL)
DATABASE_URL=postgresql://localhost:5432/manuforti
# For production:
# DATABASE_URL=postgresql://user:password@host:5432/manuforti?sslmode=require

# Stripe (https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Vipps (https://developer.vippsmobilepay.com/)
VIPPS_CLIENT_ID=your_client_id
VIPPS_CLIENT_SECRET=your_client_secret
VIPPS_SUBSCRIPTION_KEY=your_subscription_key
VIPPS_MERCHANT_SERIAL_NUMBER=your_merchant_serial
# Use https://apitest.vipps.no for testing
VIPPS_BASE_URL=https://apitest.vipps.no

# SendGrid (https://app.sendgrid.com/settings/api_keys)
SENDGRID_API_KEY=SG.your_api_key
EMAIL_FROM=orders@manuforti.com
EMAIL_FROM_NAME="Manu Forti Intelligence"

# Aiden Notification Webhook
# This is where order notifications are sent
AIDEN_WEBHOOK_URL=http://localhost:3001/webhooks/orders
AIDEN_WEBHOOK_SECRET=your_webhook_secret

# AWS S3 for file uploads (optional - can use local storage for dev)
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
S3_BUCKET=manuforti-uploads
S3_REGION=eu-north-1

# Admin API Key (for admin endpoints)
ADMIN_API_KEY=change_this_in_production

# Frontend URL (for CORS and redirects)
FRONTEND_URL=http://localhost:8080
