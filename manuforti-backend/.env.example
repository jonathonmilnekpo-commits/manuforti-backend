# Server Configuration
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:8080

# Database (PostgreSQL)
# For local development:
DATABASE_URL=postgresql://user:password@localhost:5432/manuforti
# For Railway (they provide this automatically):
# DATABASE_URL=${{Postgres.DATABASE_URL}}

# Email Configuration (SendGrid)
SENDGRID_API_KEY=SG.your_api_key_here
EMAIL_FROM=orders@manuforti.no
EMAIL_FROM_NAME=Manu Forti Intelligence
JONATHON_EMAIL=Jonathon.Milne137@gmail.com

# Aiden/OpenClaw Notifications
# This is the URL where Aiden receives webhook notifications
# For local testing: http://localhost:3000/webhook/orders
# For production: https://your-railway-app.up.railway.app/webhook/orders
AIDEN_WEBHOOK_URL=http://localhost:3000/webhook/orders
AIDEN_WEBHOOK_SECRET=your_webhook_secret_here

# Optional: Payment Providers (if adding Stripe/Vipps later)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# VIPPS_CLIENT_ID=...
# VIPPS_CLIENT_SECRET=...
# VIPPS_SUBSCRIPTION_KEY=...
